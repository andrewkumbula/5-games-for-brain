[Unit]
Description=FiveLetters Telegram Bot
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/fiveletters
EnvironmentFile=/opt/fiveletters/.env
ExecStart=/opt/fiveletters/.venv/bin/python /opt/fiveletters/main.py
Restart=always
RestartSec=3
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
